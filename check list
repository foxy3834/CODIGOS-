    def toggle_expand(self):
        """Expande ou recolhe o card"""
        self.expandido = not self.expandido
        
        if self.expandido:
            self.detalhes_frame.show()
            self.expand_btn.setText("▲")
            # Animar altura
            self.detalhes_frame.setMaximumHeight(0)
            self.animation.setStartValue(0)
            self.animation.setEndValue(self.detalhes_frame.sizeHint().height())
            self.animation.start()
        else:
            self.expand_btn.setText("▼")
            # Animar recolhimento
            self.animation.setStartValue(self.detalhes_frame.height())
            self.animation.setEndValue(0)
            self.animation.finished.connect(self.detalhes_frame.hide)
            self.animation.start()


