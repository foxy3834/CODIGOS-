    def limpar_area(self):
        """Limpa a área de conteúdo"""
        while self.scroll_layout.count():
            item = self.scroll_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
        self.checkboxes.clear()
    
    def atualizar_header(self, titulo):
        """Atualiza o título do header"""
        self.titulo_header.setText(titulo)
    
    def atualizar_status(self):
        """Atualiza informações de status no menu"""
        total = self.contar_checklists()
        ultima = self.obter_ultima_checklist()
        
        self.label_total.setText(f"📊 Total: {total} checklist(s)")
        if ultima:
            self.label_ultima.setText(f"🕐 Última: {ultima}")
    
    def contar_checklists(self):
        """Retorna número total de checklists"""
        try:
            return len(self.carregar_historico())
        except:
            return 0
    
    def obter_ultima_checklist(self):
        """Retorna data da última checklist"""
        try:
            dados = self.carregar_historico()
            if dados:
                ultima = dados[-1]
                data = datetime.fromisoformat(ultima['data'])
                return data.strftime("%d/%m/%Y")
        except:
            pass
        return None
    
    def carregar_historico(self, forcar_recarregar=False):
        """Carrega histórico com cache"""
        if self.historico_cache is None or forcar_recarregar:
            if os.path.exists(ARQUIVO):
                with open(ARQUIVO, "r", encoding='utf-8') as f:
                    self.historico_cache = json.load(f)
            else:
                self.historico_cache = []
        return self.historico_cache.copy()
    
    def salvar_historico(self, dados):
        """Salva histórico e atualiza cache"""
        with open(ARQUIVO, "w", encoding='utf-8') as f:
            json.dump(dados, f, indent=4, ensure_ascii=False)
        self.historico_cache = dados
        self.atualizar_status()
    
