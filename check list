    def finalizar(self):
        """Finaliza e salva a checklist"""
        try:
            # Salvar comentários
            self.checklist["comentarios"] = self.texto_comentarios.toPlainText()
            
            if self.editando_index is not None:
                # Modo edição
                dados = self.carregar_historico()
                dados[self.editando_index] = self.checklist
                self.salvar_historico(dados)
                QMessageBox.information(
                    self,
                    "Sucesso",
                    "✅ Checklist atualizada com sucesso!"
                )
            else:
                # Modo novo
                dados = self.carregar_historico()
                dados.append(self.checklist)
                self.salvar_historico(dados)
                QMessageBox.information(
                    self,
                    "Sucesso",
                    "✅ Checklist salva com sucesso!"
                )
            
            self.editando_index = None
            self.mostrar_tela_historico()
            
        except Exception as e:
            QMessageBox.critical(
                self,
                "Erro",
                f"Ocorreu um erro ao salvar: {str(e)}"
            )
    
