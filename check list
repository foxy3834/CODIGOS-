    def editar_checklist(self, index):
        """Edita checklist existente"""
        dados = self.carregar_historico()
        self.checklist = dados[index].copy()
        self.editando_index = index
        
        # Ir para a tela inicial
        self.mostrar_tela_inicio()
    
    def excluir_checklist(self, index):
        """Exclui checklist com confirmação"""
        reply = QMessageBox.question(
            self,
            "Confirmar Exclusão",
            "Tem certeza que deseja excluir esta checklist?\n\nEsta ação não pode ser desfeita.",
            QMessageBox.Yes | QMessageBox.No
        )
        
        if reply == QMessageBox.Yes:
            dados = self.carregar_historico()
            dados.pop(index)
            self.salvar_historico(dados)
            self.mostrar_tela_historico()
            QMessageBox.information(self, "Sucesso", "Checklist excluída com sucesso!")
    
    def duplicar_checklist(self, index):
        """Duplica uma checklist existente"""
        dados = self.carregar_historico()
        nova = dados[index].copy()
        nova["nome"] = f"{nova['nome']} (Cópia)"
        nova["data"] = datetime.now().isoformat()
        
        dados.append(nova)
        self.salvar_historico(dados)
        self.mostrar_tela_historico()
        QMessageBox.information(self, "Sucesso", "Checklist duplicada com sucesso!")


